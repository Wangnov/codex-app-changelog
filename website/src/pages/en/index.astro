---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const entries = (await getCollection('changelog_en')).sort(
  (a, b) => b.data.build - a.data.build,
);
---
<Base title="Codex App Changelog · Unofficial" lang="en">
  <ul class="version-list">
    {entries.map((e) => (
      <li>
        <a class="version-item" href={`/changelog/en/${e.data.version}/`}>
          <div class="version-head">
            <span class="version-num">{e.data.version}</span>
            <span class="version-build">build {e.data.build}</span>
            {e.data.win_version && <span class="platform-badge">+ Win</span>}
            <span class="version-date">{e.data.released}</span>
          </div>
          <p class="version-summary">{e.data.summary}</p>
        </a>
      </li>
    ))}
  </ul>
</Base>
