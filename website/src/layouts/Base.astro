---
import '../styles/global.css';
const { title, description, lang = 'zh', version } = Astro.props;
const isZh = lang === 'zh';
const desc =
  description ??
  (isZh
    ? '第三方、自动化的 OpenAI Codex 桌面版逆向变更日志'
    : 'Automated third-party reverse-engineered changelog for the OpenAI Codex desktop app');
const tagline = isZh
  ? '基于官方 Sparkle 更新包逆向重建,逐版还原 OpenAI Codex 桌面版「具体改了什么」——补上官方不写的那一层。'
  : 'Reverse-rebuilt from official Sparkle update packages to recover what actually changed in each OpenAI Codex desktop release — the layer the official notes leave out.';
const home = isZh ? '/changelog/' : '/changelog/en/';
const rss = isZh ? '/changelog/rss.xml' : '/changelog/en/rss.xml';
// 语言切换:在单篇页保持同一版本切语言,在列表页切到对应语言首页
const zhHref = version ? `/changelog/${version}/` : '/changelog/';
const enHref = version ? `/changelog/en/${version}/` : '/changelog/en/';
---
<!doctype html>
<html lang={isZh ? 'zh-CN' : 'en'}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={desc} />
    <link rel="alternate" type="application/rss+xml" title="Codex App Changelog" href={rss} />
  </head>
  <body>
    <header class="site-header">
      <div class="wrap">
        <h1 class="site-title">
          <span class="prompt">$</span> codex-app-changelog
          <span class="badge-unofficial">{isZh ? '非官方' : 'unofficial'}</span>
        </h1>
        <p class="site-tagline">{tagline}</p>
        <nav class="site-nav">
          <a href={home}>{isZh ? '版本列表' : 'Versions'}</a>
          <a href={rss}>RSS</a>
          <a href="https://github.com/Wangnov/codex-app-changelog">GitHub</a>
          <span class="lang-switch">
            <a href={zhHref} class={isZh ? 'active' : ''}>中</a>
            <a href={enHref} class={!isZh ? 'active' : ''}>EN</a>
          </span>
        </nav>
      </div>
    </header>
    <main class="wrap"><slot /></main>
    <footer class="site-footer">
      <div class="wrap">
        <span>{isZh
          ? '与 OpenAI 无关 · 不重分发官方二进制 · 仅发布差异结论'
          : 'Not affiliated with OpenAI · No official binaries redistributed · diff conclusions only'}</span>
        <span>{isZh ? '由 codex exec 自动归纳生成' : 'Generated by codex exec'}</span>
      </div>
    </footer>
  </body>
</html>
